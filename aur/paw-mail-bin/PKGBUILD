source_x86_64=("${_base_url}/paw-mail-x86_64-linux.tar.gz")
source_aarch64=("${_base_url}/paw-mail-aarch64-linux.tar.gz")

sha256sums_x86_64=('00460aab13e9c13b6afd289f8cdcfbfa82fef5c108731419848009ca8e15f109')
sha256sums_aarch64=('44ddae0cbc199dda0d4226136a144bfda9cb856d01f66cb1bca533b723369c8f')

package() {
    install -Dm755 paw-mail "${pkgdir}/usr/bin/paw-mail"
}
