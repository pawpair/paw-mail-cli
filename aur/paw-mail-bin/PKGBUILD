# Maintainer: pawpair <packages@pawpair.com>
pkgname=paw-mail-bin
pkgver=0.1.0-alpha.9
pkgrel=1
pkgdesc="Paw Mail email client — unified CLI and TUI"
arch=('x86_64' 'aarch64')
url="https://github.com/pawpair/paw-mail-cli"
license=('MIT')
provides=('paw-mail')
conflicts=('paw-mail')
optdepends=('paw-mail-cli-bin: standalone CLI interface'
            'paw-mail-tui-bin: standalone TUI interface')

